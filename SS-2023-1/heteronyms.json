{
  "_meta": {
    "purpose": "TTS 破音字(多音字)地雷表。pipeline.py 的 scan_heteronyms() 會在解析講稿後掃描並提醒;搭配 --verify 可實際確認發音。",
    "source": "改編自 speechlab0210/video-production-skill references/heteronyms.json (MIT)。原始觀察對象為 ElevenLabs multilingual_v2;Azure zh-TW 神經語音對破音字判斷通常正確,故本表僅提醒不阻擋。",
    "usage": "被標記的詞:優先考慮改寫;或用 [[顯示|朗讀]] 語法餵同音替身字(字幕仍顯示正確字);或跑 --verify 用 ASR 回驗確認。",
    "last_updated": "2026-07-15"
  },
  "chars": {
    "還": {
      "readings": { "hái": "仍然/還是/還在/還有", "huán": "歸還/償還/還給/還錢" },
      "status": "confirmed",
      "rule": "ElevenLabs 兩個方向都會錯;Azure 通常正確但含「還給/歸還」時建議 --verify",
      "rewrites": {
        "還是": "仍然 / 依然",
        "還有": "另外 / 而且",
        "還在": "仍在",
        "還要": "仍要 / 依然要",
        "還給": "退回 / 交回",
        "歸還": "退回 / 交回"
      }
    },
    "行": {
      "readings": { "xíng": "前行/可行/行動", "háng": "銀行/行業/一行字" },
      "status": "suspected",
      "rule": "前後文足以消歧通常 OK,含「行業」「銀行」「一行」時留意",
      "rewrites": {}
    },
    "重": {
      "readings": { "zhòng": "重要/重量/沉重", "chóng": "重複/重新/重來" },
      "status": "suspected",
      "rule": "「重新 / 重複」要特別檢查",
      "rewrites": { "重新": "再次", "重複": "反覆" }
    },
    "長": {
      "readings": { "cháng": "長度/長期", "zhǎng": "成長/長大/隊長/家長" },
      "status": "suspected",
      "rule": "「長大 / 成長 / ○長(職稱)」要檢查",
      "rewrites": {}
    },
    "得": {
      "readings": { "dé": "獲得/得到", "děi": "必須/不得不", "de": "助詞「做得好」" },
      "status": "suspected",
      "rule": "助詞 de 偶爾被誤讀,長句抽查",
      "rewrites": {}
    },
    "差": {
      "readings": { "chā": "差別/差距", "chà": "差勁/差點", "chāi": "出差/差事" },
      "status": "suspected",
      "rule": "工程講稿常見「應力差/溫差/差值」,三讀音易混,建議 --verify",
      "rewrites": {}
    },
    "便": {
      "readings": { "biàn": "方便/便利", "pián": "便宜" },
      "status": "suspected",
      "rule": "「便宜」要檢查",
      "rewrites": {}
    },
    "強": {
      "readings": { "qiáng": "強度/強大", "qiǎng": "勉強", "jiàng": "倔強" },
      "status": "suspected",
      "rule": "結構工程講稿高頻字(強度/補強);「勉強」要檢查",
      "rewrites": { "勉強": "刻意 / 硬是" }
    },
    "載": {
      "readings": { "zài": "載重/承載/載具", "zǎi": "記載/千載" },
      "status": "suspected",
      "rule": "工程講稿高頻字(載重/活載重);「記載」要檢查",
      "rewrites": { "記載": "記錄" }
    },
    "應": {
      "readings": { "yìng": "應力/反應/對應", "yīng": "應該/應當" },
      "status": "suspected",
      "rule": "結構講稿最高頻破音字之一(應力 yìng);一般 context 可消歧,首次使用新語音時 --verify 抽查",
      "rewrites": {}
    }
  }
}
